# ============================================================
# JobBot Backend Environment Variables
# ============================================================

# ---- Server ----
NODE_ENV=development
PORT=4000
API_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:5173,http://localhost:4173

# ---- Database ----
DATABASE_URL=postgresql://jobbot:jobbot@localhost:5432/jobbot?schema=public

# ---- JWT ----
JWT_ACCESS_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_SALT_ROUNDS=12

# ---- Rate limiting ----
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
AUTH_RATE_LIMIT_MAX=20

# ---- Logging ----
LOG_LEVEL=info

# ---- Telegram (GramJS) ----
TELEGRAM_API_ID=0
TELEGRAM_API_HASH=
TELEGRAM_SESSION=
TELEGRAM_RECONNECT_RETRIES=10
TELEGRAM_RECONNECT_DELAY_MS=5000

# ---- Gemini ----
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_MAX_RETRIES=3
GEMINI_RETRY_DELAY_MS=2000

# ---- SMTP / Email ----
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_NAME=JobBot
SMTP_FROM_EMAIL=
EMAIL_MAX_RETRIES=3
EMAIL_RETRY_DELAY_MS=3000

# ---- Automation defaults ----
DEFAULT_MATCH_THRESHOLD=70
AUTO_APPLY_ENABLED=false
