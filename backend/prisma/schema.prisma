// ============================================================
// JobBot Prisma schema
// PostgreSQL data source with full relational model
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ----------------------------- Enums -----------------------------

enum UserRole {
  ADMIN
  USER
}

enum ChannelStatus {
  ACTIVE
  PAUSED
  ERROR
}

enum JobStatus {
  DETECTED
  MATCHED
  DRAFTED
  APPLIED
  SKIPPED
  ARCHIVED
}

enum RemoteType {
  REMOTE
  ONSITE
  HYBRID
  UNKNOWN
}

enum MatchRecommendation {
  STRONG_APPLY
  APPLY
  CONSIDER
  SKIP
}

enum DraftStatus {
  PENDING
  APPROVED
  REJECTED
  SENT
}

enum ApplicationStatus {
  QUEUED
  SENDING
  SENT
  FAILED
  SKIPPED
}

enum NotificationType {
  APPLICATION_SENT
  APPLICATION_FAILED
  HIGH_SCORE_JOB
  SYSTEM_STOPPED
  SYSTEM_STARTED
}

enum LogLevel {
  TRACE
  DEBUG
  INFO
  WARN
  ERROR
  FATAL
}

enum LogCategory {
  TELEGRAM
  AI
  EMAIL
  AUTH
  SYSTEM
  ERROR
}

// ----------------------------- Models -----------------------------

model User {
  id           String   @id @default(uuid()) @db.Uuid
  email        String   @unique
  passwordHash String   @map("password_hash")
  role         UserRole @default(USER)
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  profile          Profile?
  channels         TelegramChannel[]
  jobs             Job[]
  matches          JobMatch[]
  drafts           ApplicationDraft[]
  applications     Application[]
  notifications    Notification[]
  settings         Setting?
  refreshTokens    RefreshToken[]

  @@index([email])
  @@index([role])
  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  tokenHash String   @unique @map("token_hash")
  expiresAt DateTime @map("expires_at")
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model Profile {
  id                 String   @id @default(uuid()) @db.Uuid
  userId             String   @unique @map("user_id") @db.Uuid
  fullName           String   @map("full_name")
  email              String
  phone              String?
  portfolio          String?
  linkedin           String?
  github             String?
  resumeText         String?  @map("resume_text") @db.Text
  skills             String[]
  preferredRoles     String[] @map("preferred_roles")
  preferredLocations String[] @map("preferred_locations")
  expectedSalary     Int?     @map("expected_salary")
  minMatchScore      Int      @default(70) @map("min_match_score")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("profiles")
}

model TelegramChannel {
  id          String        @id @default(uuid()) @db.Uuid
  userId      String        @map("user_id") @db.Uuid
  channelId   String        @map("channel_id")
  title       String
  username    String?
  status      ChannelStatus @default(ACTIVE)
  lastMessageAt DateTime?   @map("last_message_at")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  user     User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages TelegramMessage[]

  @@unique([userId, channelId])
  @@index([userId])
  @@index([status])
  @@map("telegram_channels")
}

model TelegramMessage {
  id              String   @id @default(uuid()) @db.Uuid
  channelId       String   @map("channel_id") @db.Uuid
  telegramMsgId   String   @map("telegram_msg_id")
  rawText         String   @map("raw_text") @db.Text
  senderId        String?  @map("sender_id")
  isJobPost       Boolean  @default(false) @map("is_job_post")
  messageDate     DateTime @map("message_date")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  channel TelegramChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  job     Job?

  @@unique([channelId, telegramMsgId])
  @@index([channelId])
  @@index([isJobPost])
  @@index([messageDate])
  @@map("telegram_messages")
}

model Job {
  id           String     @id @default(uuid()) @db.Uuid
  userId       String     @map("user_id") @db.Uuid
  messageId    String?    @unique @map("message_id") @db.Uuid
  title        String
  company      String?
  contactEmail String?    @map("contact_email")
  contactPhone String?    @map("contact_phone")
  experience   String?
  salary       String?
  remoteType   RemoteType @default(UNKNOWN) @map("remote_type")
  deadline     DateTime?
  description  String     @db.Text
  rawText      String     @map("raw_text") @db.Text
  contentHash  String     @map("content_hash")
  status       JobStatus  @default(DETECTED)
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  message      TelegramMessage?  @relation(fields: [messageId], references: [id], onDelete: SetNull)
  skills       JobSkill[]
  locations    JobLocation[]
  match        JobMatch?
  drafts       ApplicationDraft[]
  applications Application[]

  @@unique([userId, contentHash])
  @@index([userId])
  @@index([status])
  @@index([company])
  @@index([createdAt])
  @@map("jobs")
}

model JobSkill {
  id        String   @id @default(uuid()) @db.Uuid
  jobId     String   @map("job_id") @db.Uuid
  name      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([jobId, name])
  @@index([jobId])
  @@index([name])
  @@map("job_skills")
}

model JobLocation {
  id        String   @id @default(uuid()) @db.Uuid
  jobId     String   @map("job_id") @db.Uuid
  name      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([jobId, name])
  @@index([jobId])
  @@index([name])
  @@map("job_locations")
}

model JobMatch {
  id             String              @id @default(uuid()) @db.Uuid
  jobId          String              @unique @map("job_id") @db.Uuid
  userId         String              @map("user_id") @db.Uuid
  score          Int
  strengths      String[]
  weaknesses     String[]
  reason         String              @db.Text
  recommendation MatchRecommendation
  createdAt      DateTime            @default(now()) @map("created_at")
  updatedAt      DateTime            @updatedAt @map("updated_at")

  job  Job  @relation(fields: [jobId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([score])
  @@index([recommendation])
  @@map("job_matches")
}

model ApplicationDraft {
  id        String      @id @default(uuid()) @db.Uuid
  jobId     String      @map("job_id") @db.Uuid
  userId    String      @map("user_id") @db.Uuid
  subject   String
  body      String      @db.Text
  toEmail   String      @map("to_email")
  status    DraftStatus @default(PENDING)
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")

  job         Job          @relation(fields: [jobId], references: [id], onDelete: Cascade)
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  application Application?

  @@index([jobId])
  @@index([userId])
  @@index([status])
  @@map("application_drafts")
}

model Application {
  id         String            @id @default(uuid()) @db.Uuid
  jobId      String            @map("job_id") @db.Uuid
  userId     String            @map("user_id") @db.Uuid
  draftId    String?           @unique @map("draft_id") @db.Uuid
  toEmail    String            @map("to_email")
  subject    String
  body       String            @db.Text
  status     ApplicationStatus @default(QUEUED)
  attempts   Int               @default(0)
  error      String?           @db.Text
  messageId  String?           @map("message_id")
  sentAt     DateTime?         @map("sent_at")
  createdAt  DateTime          @default(now()) @map("created_at")
  updatedAt  DateTime          @updatedAt @map("updated_at")

  job   Job               @relation(fields: [jobId], references: [id], onDelete: Cascade)
  user  User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  draft ApplicationDraft? @relation(fields: [draftId], references: [id], onDelete: SetNull)

  @@unique([userId, jobId])
  @@index([userId])
  @@index([jobId])
  @@index([status])
  @@index([sentAt])
  @@map("applications")
}

model Notification {
  id        String           @id @default(uuid()) @db.Uuid
  userId    String           @map("user_id") @db.Uuid
  type      NotificationType
  title     String
  message   String           @db.Text
  metadata  Json?
  isRead    Boolean          @default(false) @map("is_read")
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
  @@index([isRead])
  @@index([createdAt])
  @@map("notifications")
}

model Setting {
  id                String   @id @default(uuid()) @db.Uuid
  userId            String   @unique @map("user_id") @db.Uuid
  automationPaused  Boolean  @default(true) @map("automation_paused")
  autoApply         Boolean  @default(false) @map("auto_apply")
  matchThreshold    Int      @default(70) @map("match_threshold")
  notifyOnHighScore Boolean  @default(true) @map("notify_on_high_score")
  notifyOnSent      Boolean  @default(true) @map("notify_on_sent")
  notifyOnFailed    Boolean  @default(true) @map("notify_on_failed")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("settings")
}

model Log {
  id        String      @id @default(uuid()) @db.Uuid
  level     LogLevel
  category  LogCategory
  message   String      @db.Text
  context   Json?
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")

  @@index([level])
  @@index([category])
  @@index([createdAt])
  @@map("logs")
}
